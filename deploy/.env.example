# ============================================================================
# Конфигурация Fix Logistics на собственном VPS
# Скопируй в .env и подставь реальные значения
# Сгенерировать JWT/ключи: см. deploy/scripts/generate-keys.sh
# ============================================================================

# ---------- PostgreSQL ----------
POSTGRES_PASSWORD=ЗАМЕНИ_сильный_пароль_минимум_32_символа
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ---------- JWT (auth) ----------
# Минимум 32 символа, использовать openssl rand -base64 48
JWT_SECRET=ЗАМЕНИ_jwt_secret_минимум_32_символа_случайных
JWT_EXPIRY=3600

# ANON_KEY и SERVICE_ROLE_KEY — JWT-токены, подписанные JWT_SECRET выше
# Сгенерируй их через deploy/scripts/generate-keys.sh
ANON_KEY=eyJ...замени...
SERVICE_ROLE_KEY=eyJ...замени...

# Используется Realtime, отдельный длинный секрет
SECRET_KEY_BASE=ЗАМЕНИ_секрет_минимум_64_символа_openssl_rand_base64_64

# ---------- Внешние URL ----------
# Публичный адрес API gateway (Kong) — то, что будет в VITE_SUPABASE_URL фронта
API_EXTERNAL_URL=https://api.example.ru
# Адрес самого приложения (используется в emails для magic links)
SITE_URL=https://app.example.ru
ADDITIONAL_REDIRECT_URLS=https://app.example.ru

# ---------- Порты на VPS ----------
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
WEB_HTTP_PORT=8080

# ---------- Регистрация/email ----------
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false

# ---------- SMTP (для подтверждения email и восстановления пароля) ----------
# Российские варианты: smtp.yandex.ru, smtp.mail.ru, smtp.beget.com
SMTP_ADMIN_EMAIL=admin@example.ru
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@example.ru
SMTP_PASS=пароль_приложения_yandex
SMTP_SENDER_NAME=Fix Logistics

# ---------- Studio (админка БД) ----------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=ЗАМЕНИ_пароль_админки

# ---------- PostgREST схемы ----------
PGRST_DB_SCHEMAS=public,storage

# ---------- Секреты edge-функций ----------
LOVABLE_API_KEY=
TELEGRAM_BOT_TOKEN=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
